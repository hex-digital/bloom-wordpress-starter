{
  "name": "hex-digital/bloom",
  "description": "Opinionated WordPress starter layer for Roots Sage",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Hex Digital",
      "homepage": "https://hexdigital.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Bloom\\": "src/"
    }
  },
  "require": {
    "php": ">=8.2",
    "roots/acorn": "^6.0",
    "illuminate/process": "^13.0",
    "hex-digital/bloom-modules": "dev-main",
    "livewire/livewire": "^3.4",
    "log1x/acf-composer": "^3.4",
    "log1x/navi": "^3.1",
    "log1x/poet": "^2.1",
    "spatie/laravel-data": "^4.19",
    "blade-ui-kit/blade-icons": "^1.8"
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/hex-digital/bloom-modules.git"
    }
  ],
  "require-dev": {
    "laravel/pint": "^1.29"
  },
  "scripts": {
    "lint": "pint --test",
    "format": "pint"
  },
  "extra": {
    "acorn": {
      "providers": [
        "Bloom\\BloomServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
